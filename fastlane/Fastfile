# Stop-smoking — one-command iOS publishing (fastlane). Shares the account-level App Store
# Connect API key in ~/eas-secrets (referenced BY PATH; never copied into the repo).
#
#   fastlane ios pull      download the live App Store listing (read-only)
#   fastlane ios beta      build -> TestFlight (does NOT touch the live App Store version)
#   fastlane ios release   build -> metadata/screenshots -> submit for review
ASC_KEY_JSON = File.expand_path("~/eas-secrets/asc_api_key.json")
PROJECT = "Nefes/Nefes.xcodeproj"
SCHEME  = "Nefes"

platform :ios do
  P8   = File.expand_path("~/eas-secrets/AuthKey_B5KA5HPZ8L.p8")
  AUTH = "-allowProvisioningUpdates -authenticationKeyPath #{P8} -authenticationKeyID B5KA5HPZ8L -authenticationKeyIssuerID fe1d0eff-62b6-41a9-8938-dce2f708344c"

  desc "Build a signed App Store .ipa (headless signing via API key + the on-machine Apple Distribution cert)"
  lane :build do
    build_app(project: PROJECT, scheme: SCHEME, export_method: "app-store",
              output_directory: "build", xcargs: AUTH)
  end

  desc "Build + upload to TestFlight (separate beta channel; live version untouched)"
  lane :beta do
    build
    upload_to_testflight(api_key_path: ASC_KEY_JSON, skip_waiting_for_build_processing: true)
  end

  desc "Build + push metadata/screenshots + submit for App Store review"
  lane :release do
    build
    deliver(api_key_path: ASC_KEY_JSON, submit_for_review: true, automatic_release: true,
            force: true, run_precheck_before_submit: false)
  end

  desc "Download the live App Store listing (read-only)"
  lane :pull do
    sh("cd .. && fastlane deliver download_metadata --api_key_path #{ASC_KEY_JSON} -a com.nefesapp.ios")
  end

  desc "Register the com.nefesapp.ios Bundle ID in the Developer Portal (so it appears in App Store Connect's New App dropdown)"
  lane :register_id do
    app_store_connect_api_key(
      key_id: "B5KA5HPZ8L",
      issuer_id: "fe1d0eff-62b6-41a9-8938-dce2f708344c",
      key_filepath: File.expand_path("~/eas-secrets/AuthKey_B5KA5HPZ8L.p8"),
    )
    produce(
      app_identifier: "com.nefesapp.ios",
      app_name: "Nefes: Sigara Bırakma",
      language: "Turkish",
      sku: "nefes-app-2026",
      platforms: ["ios"],
      skip_itc: true, # only register the App ID in the Developer Portal; skip the web-session app creation
    )
  end
end
